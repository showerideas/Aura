<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for Android Auto projection -->
    <uses-feature
        android:name="android.hardware.type.automotive"
        android:required="false" />

    <application
        android:allowBackup="false"
        android:label="AURA Auto"
        android:theme="@android:style/Theme.DeviceDefault">

        <!--
            AuraCarAppService — entry point for the Android Auto head unit.
            The system binds this when the driver connects a device or
            Automotive OS launches the app from the app launcher.
        -->
        <service
            android:name=".AuraCarAppService"
            android:exported="true"
            android:label="AURA">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <category android:name="androidx.car.app.category.POI" />
            </intent-filter>
        </service>

        <!--
            Phase G1 — Voice action registration for Android Auto.

            Registers "start exchange" as a car voice action so the driver can
            say "Hey Google, start an AURA exchange" to trigger the exchange flow
            hands-free. The voice action maps to the CarAppService entry point;
            the system routes it to IdleScreen → AdvertisingScreen.

            android.intent.action.SEARCH_LONG_PRESS is the standard Car App Library
            mechanism for voice-initiated feature activation.

            The carVoiceInteraction meta-data file lists the voice-action intents
            the app can handle (see res/xml/automotive_app_desc.xml).
        -->
        <activity
            android:name=".AuraVoiceActivity"
            android:exported="true"
            android:label="AURA"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Google Assistant voice action for starting an exchange -->
            <intent-filter>
                <action android:name="android.intent.action.SEARCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
            AuraBiometricAutoService — Phase G2 biometric-only auth gate.
            Invoked by IdleScreen when the Car App detects camera is unavailable
            (Automotive OS does not expose the phone camera to Auto sessions).
            Uses BiometricPrompt via a transparent Activity to satisfy the auth
            gate before allowing the exchange to proceed.
        -->
        <activity
            android:name=".AuraBiometricAutoActivity"
            android:exported="false"
            android:label="AURA Authentication"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

    </application>
</manifest>
