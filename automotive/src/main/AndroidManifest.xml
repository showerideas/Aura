<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for Android Auto projection -->
    <uses-feature
        android:name="android.hardware.type.automotive"
        android:required="false" />

    <application
        android:allowBackup="false"
        android:label="AURA Auto"
        android:theme="@android:style/Theme.DeviceDefault">

        <!--
            AuraCarAppService — entry point for the Android Auto head unit.
            The system binds this when the driver connects a device or
            Automotive OS launches the app from the app launcher.
        -->
        <service
            android:name=".AuraCarAppService"
            android:exported="true"
            android:label="AURA">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <category android:name="androidx.car.app.category.POI" />
            </intent-filter>
        </service>
    </application>
</manifest>
