<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Declares this is a Wear OS app -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Wearable Data Layer — required for ChannelClient -->
    <uses-permission android:name="com.google.android.permission.PROVIDE_BACKGROUND" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="false"
        android:label="AURA"
        android:theme="@android:style/Theme.DeviceDefault">

        <!--
            AuraTileService — provides the AURA exchange status tile to the
            Wear OS tile carousel. The system binds this service when the user
            adds or views the tile.
        -->
        <service
            android:name=".AuraTileService"
            android:exported="true"
            android:label="AURA"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
        </service>

        <!--
            WearPhoneBridge — WearableListenerService that receives exchange
            state updates from the paired phone via ChannelClient.
        -->
        <service
            android:name=".WearPhoneBridge"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.CHANNEL_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>
