<?xml version="1.0" encoding="utf-8"?>
<!--
  Rounded rectangle background for small badge chips (e.g. "Active" badge
  in the profile switcher bottom sheet).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="12dp" />
    <stroke
        android:width="1dp"
        android:color="@color/aura_cyan" />
</shape>
