<?xml version="1.0" encoding="utf-8"?>
<!--
  Rounded-rectangle background for the gesture-auth section cards shown in
  ExchangeFragment, RoomExchangeFragment, and the ProfileFragment recording
  area. Matches the 12dp corner radius used on PreviewViews and contact cards
  throughout the app.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/surface_variant" />
    <corners android:radius="12dp" />
</shape>
