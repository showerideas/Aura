<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- MDM status banner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/tv_mdm_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textAppearance="?attr/textAppearanceTitleMedium" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Policy rows -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="1dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <include layout="@layout/item_policy_row"
                    android:id="@+id/row_max_attempts" />

                <include layout="@layout/item_policy_row"
                    android:id="@+id/row_retention" />

                <include layout="@layout/item_policy_row"
                    android:id="@+id/row_sas" />

                <include layout="@layout/item_policy_row"
                    android:id="@+id/row_backup" />

                <include layout="@layout/item_policy_row"
                    android:id="@+id/row_tor" />

                <include layout="@layout/item_policy_row"
                    android:id="@+id/row_pin" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Individual policy value TextViews referenced in Fragment -->
        <TextView android:id="@+id/tv_max_attempts" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:visibility="gone" />
        <TextView android:id="@+id/tv_retention_days" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:visibility="gone" />
        <TextView android:id="@+id/tv_require_sas" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:visibility="gone" />
        <TextView android:id="@+id/tv_backup_disabled" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:visibility="gone" />
        <TextView android:id="@+id/tv_tor_disabled" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:visibility="gone" />
        <TextView android:id="@+id/tv_pin_lock" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:visibility="gone" />
    </LinearLayout>
</ScrollView>
