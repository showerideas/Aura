<?xml version="1.0" encoding="utf-8"?>
<!-- Phase 10.4 — Encrypted backup / restore screen (polished) -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_backup"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        app:title="@string/backup_title"
        app:titleTextColor="@color/on_surface"
        app:navigationIcon="@drawable/ic_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/backup_description"
                android:textColor="@color/on_surface_secondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4" />

            <!-- Live contact count chip -->
            <TextView
                android:id="@+id/tv_contact_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/chip_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textColor="@color/aura_cyan_dark"
                android:textSize="13sp"
                android:text="—" />

            <!-- Export card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_variant"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/backup_export_title"
                        android:textColor="@color/on_surface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/backup_export_subtitle"
                        android:textColor="@color/on_surface_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_export_backup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/backup_action_export"
                        android:contentDescription="@string/backup_action_export"
                        app:backgroundTint="@color/aura_cyan_dark" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Restore card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_variant"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/backup_restore_title"
                        android:textColor="@color/on_surface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/backup_restore_subtitle"
                        android:textColor="@color/on_surface_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:id="@+id/btn_import_backup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/backup_action_restore"
                        android:contentDescription="@string/backup_action_restore"
                        app:strokeColor="@color/aura_purple_light" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Progress overlay — shown during PBKDF2 derivation / crypto -->
    <FrameLayout
        android:id="@+id/progress_backup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:indicatorColor="@color/aura_cyan_dark"
            app:trackColor="@color/surface_variant"
            android:indeterminate="true" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
