<?xml version="1.0" encoding="utf-8"?>
<!-- Phase 9.3 — Row layout for a single gesture profile slot in GestureLibraryFragment -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface_variant"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_profile_enrolled_at"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/on_surface_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Enrolled chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_enrolled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gesture_library_enrolled"
                android:visibility="gone"
                app:chipBackgroundColor="@color/aura_cyan_dark" />

            <!-- Empty slot indicator -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gesture_library_empty_slot"
                app:chipBackgroundColor="@color/surface" />
        </LinearLayout>

        <!-- Action buttons row (shown when slot is enrolled) -->
        <LinearLayout
            android:id="@+id/ll_enrolled_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test_gesture"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gesture_library_test"
                android:textColor="@color/aura_cyan"
                android:contentDescription="@string/gesture_library_test" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_rename_gesture"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gesture_library_rename"
                android:textColor="@color/aura_purple_light"
                android:contentDescription="@string/gesture_library_rename" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_gesture"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gesture_library_delete"
                android:textColor="#CF6679"
                android:contentDescription="@string/gesture_library_delete" />
        </LinearLayout>

        <!-- Enroll button (shown when slot is empty) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_enroll_gesture"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/gesture_library_enroll"
            android:textColor="@color/aura_cyan"
            android:contentDescription="@string/gesture_library_enroll" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
