<?xml version="1.0" encoding="utf-8"?>
<!--
  A single row in the exchange audit log (Phase 6.6).
  Shows: timestamp | outcome chip | channel chip | peer hash (truncated)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="12dp">

    <!-- Top row: timestamp + outcome -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_timestamp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/on_surface_secondary"
            android:textSize="12sp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_outcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="false"
            android:clickable="false"
            android:focusable="false"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Bottom row: peer identity + channel chip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_peer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/on_surface"
            android:textSize="13sp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_channel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:checkable="false"
            android:clickable="false"
            android:focusable="false"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Error code (shown only when present) -->
    <TextView
        android:id="@+id/tv_error_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/error"
        android:textSize="11sp"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#1AFFFFFF" />

</LinearLayout>
