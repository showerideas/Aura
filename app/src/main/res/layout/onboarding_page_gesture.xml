<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/onboarding_gesture_title"
        android:textColor="@color/on_surface"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/onboarding_gesture_subtitle"
        android:textColor="@color/on_surface_secondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_onboard_gesture_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:text="@string/gesture_status_no_gesture"
        android:textColor="@color/on_surface_secondary"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_onboard_record"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="16dp"
        android:text="@string/btn_record_gesture"
        app:backgroundTint="@color/aura_purple" />

    <TextView
        android:id="@+id/btn_onboard_skip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:text="@string/onboarding_gesture_skip"
        android:textColor="@color/aura_cyan"
        android:textSize="14sp" />
</LinearLayout>
