<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/onboarding_gesture_title"
        android:textColor="@color/on_surface"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/onboarding_gesture_subtitle"
        android:textColor="@color/on_surface_secondary"
        android:textSize="14sp" />

    <!-- Camera live preview — starts automatically on this page -->
    <androidx.camera.view.PreviewView
        android:id="@+id/gesture_preview_onboard"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="24dp"
        android:clipToOutline="true"
        android:background="@drawable/camera_preview_bg"
        android:contentDescription="@string/gesture_camera_preview_desc" />

    <TextView
        android:id="@+id/tv_onboard_gesture_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:accessibilityLiveRegion="polite"
        android:text="@string/gesture_no_hand"
        android:textColor="@color/on_surface_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/btn_onboard_skip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:text="@string/onboarding_gesture_skip"
        android:textColor="@color/aura_cyan"
        android:textSize="14sp" />
</LinearLayout>
