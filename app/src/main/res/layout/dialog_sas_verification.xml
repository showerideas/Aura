<?xml version="1.0" encoding="utf-8"?>
<!--
  T20 — SAS (Short Authentication String) verification dialog with countdown progress bar.

  Layout:
    ┌──────────────────────────────────┐
    │  [━━━━━━━━━━━━━━━━━━━━━━━━━━━━]  │  countdown progress bar (30s → 0)
    │       [identicon 80dp]           │  visual fingerprint from the SAS code
    │         1 2 3 - 4 5 6           │  prominent 40sp monospace digits
    │  Both phones should show the     │  instruction text
    │  same code. Ask your contact     │
    │  to read theirs aloud…           │
    └──────────────────────────────────┘

  Changes vs previous version (T20):
  - Added pb_sas_countdown: a determinate horizontal progress bar that ticks
    down from 30 to 0 so the user always knows how long they have.
    Colour is @color/aura_cyan to match the SAS code display.

  Accessibility notes:
  - tv_sas_code has accessibilityLiveRegion="polite": TalkBack reads the code on appear.
  - iv_sas_identicon: importantForAccessibility="yes" + contentDescription.
  - pb_sas_countdown: importantForAccessibility="no" — decorative timing aid.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="8dp">

    <!-- Countdown progress bar — drains right-to-left over 30 seconds -->
    <ProgressBar
        android:id="@+id/pb_sas_countdown"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginBottom="12dp"
        android:max="300"
        android:progress="300"
        android:progressTint="#00E5FF"
        android:progressBackgroundTint="#1A2A30"
        android:importantForAccessibility="no"
        android:contentDescription="" />

    <!-- Identicon — deterministic visual fingerprint for this exchange -->
    <ImageView
        android:id="@+id/iv_sas_identicon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/sas_identicon_desc"
        android:importantForAccessibility="yes" />

    <!-- SAS code — large, prominent, monospace. Live region = TalkBack reads it automatically. -->
    <TextView
        android:id="@+id/tv_sas_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="40sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textColor="#00E5FF"
        android:letterSpacing="0.25"
        android:paddingVertical="8dp"
        android:accessibilityLiveRegion="polite"
        android:importantForAccessibility="yes" />

    <!-- Instruction text -->
    <TextView
        android:id="@+id/tv_sas_instruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.3"
        android:textColor="#B0B0B0" />

</LinearLayout>
