<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom view for the SAS (Short Authentication String) verification dialog.

  Layout:
    ┌──────────────────────────────────┐
    │       [identicon 80dp]           │  visual fingerprint from the SAS code
    │         1 2 3 - 4 5 6           │  prominent 40sp monospace digits
    │  Both phones should show the     │  instruction text
    │  same code. Ask your contact     │
    │  to read theirs aloud…           │
    └──────────────────────────────────┘

  The identicon is generated from the SAS pin via IdenticonGenerator — since
  both parties derive the same SAS, they will see the same identicon, providing
  an additional visual verification channel alongside the 6-digit code.

  tv_sas_code has accessibilityLiveRegion="polite" so TalkBack announces the
  code as soon as the dialog appears — users with visual impairments can complete
  the verbal comparison without tapping around.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="8dp">

    <!-- Identicon — deterministic visual fingerprint for this exchange -->
    <ImageView
        android:id="@+id/iv_sas_identicon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/sas_identicon_desc"
        android:importantForAccessibility="yes" />

    <!-- SAS code — large, prominent, monospace. Live region = TalkBack reads it automatically. -->
    <TextView
        android:id="@+id/tv_sas_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="40sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textColor="#00E5FF"
        android:letterSpacing="0.25"
        android:paddingVertical="8dp"
        android:accessibilityLiveRegion="polite"
        android:importantForAccessibility="yes" />

    <!-- Instruction text -->
    <TextView
        android:id="@+id/tv_sas_instruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.3"
        android:textColor="#B0B0B0" />

</LinearLayout>
