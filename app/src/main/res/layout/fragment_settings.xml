<?xml version="1.0" encoding="utf-8"?>
<!--
  PR-19: Settings screen. ScrollView > LinearLayout of section rows so
  there's no rigidly fixed layout to maintain when new settings land. Each
  row is a horizontal LinearLayout with a label + control on the right;
  sections are separated by a divider and a section-header TextView.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- AUTH SECTION -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:text="@string/settings_section_auth"
            android:textColor="@color/aura_purple_light"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_auth_method"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <RadioGroup
            android:id="@+id/rg_auth_method"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <RadioButton
                android:id="@+id/rb_auth_gesture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_auth_gesture"
                android:textColor="@color/on_surface" />
            <RadioButton
                android:id="@+id/rb_auth_biometric"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_auth_biometric"
                android:textColor="@color/on_surface" />
        </RadioGroup>

        <TextView
            android:id="@+id/tv_biometric_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_biometric_unavailable"
            android:textColor="@color/on_surface_secondary"
            android:textSize="12sp"
            android:visibility="gone" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginVertical="16dp" android:background="#222" />

        <!-- ACTIVATION SECTION -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/settings_section_activation"
            android:textColor="@color/aura_purple_light"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_bg_activation"
                android:textColor="@color/on_surface"
                android:textSize="15sp" />
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_bg_activation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!--
          Prompt-2: Reliability warning — shown only when bg activation is ON.
          Surfaces the OEM-skin limitation honestly so users understand why
          triple-press may not work on their specific device.
        -->
        <TextView
            android:id="@+id/tv_volume_wake_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:padding="12dp"
            android:background="#1AFFAA00"
            android:text="@string/settings_volume_wake_warning"
            android:textColor="@color/on_surface"
            android:textSize="12sp"
            android:visibility="gone" />

        <!--
          Prompt-2: "Test triple-press now" — let the user verify
          compatibility immediately. Shown only when bg activation is ON.
        -->
        <TextView
            android:id="@+id/row_test_volume_press"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="14dp"
            android:text="@string/settings_test_volume_press"
            android:textColor="@color/aura_purple_light"
            android:textSize="15sp"
            android:visibility="gone" />

        <!--
          Accessibility mode row — shown when bg activation is enabled.
          Opens Android Accessibility settings so the user can enable
          AuraAccessibilityService for OEM-reliable volume-button activation.
        -->
        <LinearLayout
            android:id="@+id/row_accessibility_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_accessibility_mode"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_accessibility_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/settings_accessibility_disabled"
                    android:textColor="@color/on_surface_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="@color/on_surface_secondary"
                android:textSize="20sp"
                android:paddingStart="8dp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginVertical="16dp" android:background="#222" />

        <!-- SECURITY SECTION (Phase 6.5 key rotation + Phase 6.6 audit history) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/settings_section_security"
            android:textColor="@color/aura_purple_light"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/row_rotate_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical"
            android:paddingVertical="12dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_rotate_key"
                android:textColor="@color/on_surface"
                android:textSize="15sp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/settings_rotate_key_subtitle"
                android:textColor="@color/on_surface_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/row_exchange_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="14dp"
            android:text="@string/settings_exchange_history"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        
        <!-- Phase 8.3 — Tor/Orbot anonymization proxy for QR relay traffic -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_tor_proxy"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_tor_proxy_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/settings_tor_proxy_subtitle"
                    android:textColor="@color/on_surface_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_tor_proxy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/settings_tor_proxy" />
        </LinearLayout>

<View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginVertical="16dp" android:background="#222" />

        <!-- DATA SECTION -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/settings_section_data"
            android:textColor="@color/aura_purple_light"
            android:textSize="13sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/row_backup_restore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="14dp"
            android:text="@string/settings_backup_restore"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/row_blocked_devices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="14dp"
            android:text="@string/settings_blocked_devices"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/row_clear_gesture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="14dp"
            android:text="@string/settings_clear_gesture"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/row_clear_contacts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="14dp"
            android:text="@string/settings_clear_contacts"
            android:textColor="@color/error"
            android:textSize="15sp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginVertical="16dp" android:background="#222" />

        <!-- ABOUT SECTION -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/settings_section_about"
            android:textColor="@color/aura_purple_light"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="14dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_version"
                android:textColor="@color/on_surface"
                android:textSize="15sp" />
            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/row_privacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="14dp"
            android:text="@string/settings_privacy"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

    </LinearLayout>
</ScrollView>

