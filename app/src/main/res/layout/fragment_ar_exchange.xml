<?xml version="1.0" encoding="utf-8"?>
<!--
  Task 99 — AR exchange camera preview + floating card overlay.
  SceneView ARCore SurfaceView fills the full screen. The card content
  is a separate ViewGroup that SceneView renders to a SurfaceTexture and
  applies to a MaterialInstance on the ContactCardNode.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--
      SceneView ARCore SurfaceView.
      id referenced by ArExchangeFragment to initialise the ARCore session.
    -->
    <FrameLayout
        android:id="@+id/arSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Scanning indicator overlay (shown while ArExchangeState == Scanning) -->
    <LinearLayout
        android:id="@+id/layoutScanning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_pill_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:visibility="visible">

        <ProgressBar
            android:id="@+id/pbScanning"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="8dp"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tvScanningLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ar_scanning_label"
            android:textAppearance="?attr/textAppearanceBodySmall" />
    </LinearLayout>

    <!-- RSSI fallback warning badge (shown when UWB unavailable) -->
    <TextView
        android:id="@+id/tvRssiFallback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="96dp"
        android:background="@drawable/bg_pill_surface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="@string/ar_rssi_fallback_label"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:visibility="gone" />

    <!-- Gesture progress bar (shown while ArGestureExchangeBridge is collecting) -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressGesture"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="88dp"
        android:visibility="invisible" />

    <!-- Close / back button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabArClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:contentDescription="@string/ar_close_description"
        android:src="@android:drawable/ic_menu_close_clear_cancel" />

</FrameLayout>
