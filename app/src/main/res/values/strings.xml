    <!-- Permission rationale (PR-03) -->
    <string name="perm_rationale_title">AURA needs a few permissions</string>
    <string name="perm_rationale_subtitle">These let AURA find and exchange contacts with people nearby. Nothing leaves your device.</string>
    <string name="perm_rationale_open_settings">Open Settings</string>
    <string name="perm_rationale_not_now">Not now</string>
    <string name="perm_label_bluetooth_scan">Nearby scanning</string>
