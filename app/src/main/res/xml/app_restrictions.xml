<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 7.4 — Enterprise MDM managed configuration keys.
    Push these via your EMM (Managed Google Play, SOTI, VMware, etc.)
-->
<restrictions xmlns:android="http://schemas.android.com/apk/res/android">

    <restriction
        android:key="allowed_auth_methods"
        android:title="Allowed Authentication Methods"
        android:restrictionType="choice"
        android:description="@string/mdm_desc_allowed_auth_methods"
        android:defaultValue="both"
        android:entries="@array/auth_method_entries"
        android:entryValues="@array/auth_method_values" />

    <restriction
        android:key="qr_relay_enabled"
        android:title="Enable QR Code Relay"
        android:restrictionType="bool"
        android:description="@string/mdm_desc_qr_relay_enabled"
        android:defaultValue="true" />

    <restriction
        android:key="min_gesture_similarity"
        android:title="Minimum Gesture Similarity Threshold"
        android:restrictionType="string"
        android:description="@string/mdm_desc_min_gesture_similarity"
        android:defaultValue="0.75" />

    <restriction
        android:key="audit_log_retention_days"
        android:title="Audit Log Retention (days)"
        android:restrictionType="integer"
        android:description="@string/mdm_desc_audit_log_retention_days"
        android:defaultValue="90" />

    <restriction
        android:key="force_key_rotation_days"
        android:title="Force Key Rotation (days)"
        android:restrictionType="integer"
        android:description="@string/mdm_desc_force_key_rotation_days"
        android:defaultValue="0" />

</restrictions>
