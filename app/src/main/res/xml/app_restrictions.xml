<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 7.4 / 7.5 — Managed App Configuration schema.

    EMM administrators configure these restrictions via the managed app config
    in their MDM console (e.g. VMware Workspace ONE, Microsoft Intune,
    Google endpoint management). The Android RestrictionsManager delivers the
    values to EnterprisePolicy at runtime.

    F-Droid note: this file is included in the FOSS flavor and has no GMS
    dependency — RestrictionsManager is part of AOSP.

    Note: android:description MUST be a @string/ reference — inline strings
    are rejected by aapt2. All descriptions live in strings.xml under the
    restriction_desc_* namespace.
-->
<restrictions xmlns:android="http://schemas.android.com/apk/res/android">

    <restriction
        android:key="max_gesture_attempts"
        android:title="Maximum gesture authentication attempts"
        android:description="@string/restriction_desc_max_gesture_attempts"
        android:restrictionType="integer"
        android:defaultValue="5" />

    <restriction
        android:key="require_sas_verification"
        android:title="Require SAS verification"
        android:description="@string/restriction_desc_require_sas"
        android:restrictionType="bool"
        android:defaultValue="false" />

    <restriction
        android:key="disable_backup"
        android:title="Disable encrypted backup"
        android:description="@string/restriction_desc_disable_backup"
        android:restrictionType="bool"
        android:defaultValue="false" />

    <restriction
        android:key="audit_log_retention_days"
        android:title="Audit log retention (days)"
        android:description="@string/restriction_desc_audit_log_retention"
        android:restrictionType="integer"
        android:defaultValue="90" />

    <restriction
        android:key="disable_tor_proxy"
        android:title="Disable Tor/Orbot proxy"
        android:description="@string/restriction_desc_disable_tor"
        android:restrictionType="bool"
        android:defaultValue="false" />

    <restriction
        android:key="enforce_pin_lock"
        android:title="Enforce PIN lock before exchange"
        android:description="@string/restriction_desc_enforce_pin_lock"
        android:restrictionType="bool"
        android:defaultValue="false" />


    <!-- T29 — Zero-touch enrollment: pre-filled profile fields from MDM -->
    <restriction
        android:key="pre_fill_display_name"
        android:title="Pre-fill display name"
        android:description="@string/restriction_desc_pre_fill_name"
        android:restrictionType="string"
        android:defaultValue="" />

    <restriction
        android:key="pre_fill_email"
        android:title="Pre-fill email"
        android:description="@string/restriction_desc_pre_fill_email"
        android:restrictionType="string"
        android:defaultValue="" />

    <restriction
        android:key="pre_fill_org"
        android:title="Pre-fill organization"
        android:description="@string/restriction_desc_pre_fill_org"
        android:restrictionType="string"
        android:defaultValue="" />

    <restriction
        android:key="pre_fill_job_title"
        android:title="Pre-fill job title"
        android:description="@string/restriction_desc_pre_fill_job_title"
        android:restrictionType="string"
        android:defaultValue="" />

    <restriction
        android:key="pre_fill_phone"
        android:title="Pre-fill phone"
        android:description="@string/restriction_desc_pre_fill_phone"
        android:restrictionType="string"
        android:defaultValue="" />

    <restriction
        android:key="pre_fill_profile_type"
        android:title="Pre-fill profile type"
        android:description="@string/restriction_desc_pre_fill_profile_type"
        android:restrictionType="choice"
        android:defaultValue="WORK"
        android:entries="@array/profile_type_entries"
        android:entryValues="@array/profile_type_values" />

</restrictions>
