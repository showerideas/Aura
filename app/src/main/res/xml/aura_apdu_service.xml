<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 10.1 — NFC Host Card Emulation AID list for AURA.

    AID  F0 41 55 52 41 00 01
         ↑  A  U  R  A  ver
    F0xx prefix = "other" category (ISO 7816-4 §10.1).
    Using "other" prevents conflicts with payment AIDs and NFC payment apps.

    requireDeviceUnlock="false" — allows tap-exchange from the lock screen.
    The gesture-biometric gate is enforced inside the app after the HCE
    bootstrap, so unlocking the phone first is not required for the NFC tap.
-->
<host-apdu-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/app_name"
    android:requireDeviceUnlock="false">

    <aid-group
        android:category="other"
        android:description="@string/app_name">

        <!--
            AURA proprietary AID — registered with the "other" category.
            Both AURA devices must SELECT this AID before exchanging public keys.
        -->
        <aid-filter android:name="F0415552410001" />
    </aid-group>

</host-apdu-service>
