<?xml version="1.0" encoding="utf-8"?>
<!--
  Accessibility service configuration for AuraAccessibilityService.

  Privacy guarantees encoded here:
    accessibilityEventTypes="typeNone"
      → AURA does not subscribe to ANY accessibility events from other apps.
        Other apps' content, UI state, and text are completely invisible to us.

    flagRequestFilterKeyEvents
      → Only key events (volume buttons) are intercepted. This is the
        minimum capability needed for reliable triple-press detection.

    canRequestFilterKeyEvents="true"
      → Required to enable flagRequestFilterKeyEvents. Will prompt the user
        for explicit consent in the Accessibility settings page.

  The combination of typeNone + flagRequestFilterKeyEvents is intentionally
  the smallest possible accessibility surface: key events only, no UI inspection.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeAllMask"
    android:accessibilityFlags="flagRequestFilterKeyEvents"
    android:canRequestFilterKeyEvents="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:packageNames="" />
