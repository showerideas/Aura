<?xml version="1.0" encoding="utf-8"?>
<!--
    AURA backup policy: exclude the local Room database and encrypted prefs.
    These contain contact data and gesture keys that should not leave the device.
-->
<full-backup-content>
    <exclude domain="database" path="aura.db" />
    <exclude domain="sharedpref" path="aura_gesture_prefs.xml" />
</full-backup-content>
