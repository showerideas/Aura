<?xml version="1.0" encoding="utf-8"?>
<!--
    Task 45 — Static launcher shortcuts (updated from Phase 6.11).
    Accessible via long-press on the AURA launcher icon.
    Max 4 shortcuts total (system limit: pinned + dynamic + static).

    Static shortcuts (this file):
      1. start_exchange  — gesture gate launch
      2. my_card         — profile view

    Dynamic shortcuts (AuraShortcutManager.kt, runtime push):
      3. last_exchange   — "Exchange with [contact]" (updated after each exchange)
      (4th slot reserved)

    See: [developer.android.com/develop/ui/compose/system/shortcuts]
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <shortcut
        android:shortcutId="start_exchange"
        android:enabled="true"
        android:icon="@drawable/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_start_exchange_short"
        android:shortcutLongLabel="@string/shortcut_start_exchange_long"
        android:shortcutDisabledMessage="@string/shortcut_disabled">
        <intent
            android:action="com.showerideas.aura.ACTION_START_EXCHANGE"
            android:targetPackage="com.showerideas.aura"
            android:targetClass="com.showerideas.aura.ui.MainActivity" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

    <shortcut
        android:shortcutId="my_card"
        android:enabled="true"
        android:icon="@drawable/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_my_card_short"
        android:shortcutLongLabel="@string/shortcut_my_card_long"
        android:shortcutDisabledMessage="@string/shortcut_disabled">
        <intent
            android:action="com.showerideas.aura.ACTION_VIEW_PROFILE"
            android:targetPackage="com.showerideas.aura"
            android:targetClass="com.showerideas.aura.ui.MainActivity" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

</shortcuts>
